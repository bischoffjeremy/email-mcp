# IMAP (reading emails)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# SMTP (sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Optional: From address (defaults to EMAIL_USER)
# EMAIL_FROM=your-email@gmail.com

# Max results per query (default: 25)
# MAX_RESULTS=25

# Enable sending emails (disabled by default for safety)
ALLOW_SEND=false

# Enable deleting emails (disabled by default for safety)
ALLOW_DELETE=false
